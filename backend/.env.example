# Base de datos MySQL
DATABASE_URL=mysql://root:Admin123@localhost:3306/agora

# Puerto del servidor
PORT=3000

# LLM Configuration
LLM_PROVIDER=openai  # openai | anthropic
LLM_API_KEY=sk-...
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4-turbo-preview
LLM_TIMEOUT_MS=10000
LLM_MAX_RETRIES=3
LLM_TEMPERATURE=0.7

# Encryption (AES-256-GCM)
ENCRYPTION_KEY=debe_ser_32_bytes_base64_o_hex

# Rate Limiting
RATE_LIMIT_SESSIONS_PER_HOUR=10
RATE_LIMIT_MESSAGES_PER_MINUTE=30

# JWT - Secrets MUST be long and secure in production
JWT_VERIFICATION_SECRET=cambiar_este_secret_muy_largo_y_aleatorio_en_produccion_12345678901234567890
JWT_SECRET=cambiar_este_secret_muy_largo_y_aleatorio_en_produccion_abcdefghijklmnopqrstuvwxyz

# SMTP Configuration (Email Service)
# Para desarrollo, usa Mailtrap (https://mailtrap.io) o un servicio similar
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=tu_usuario_mailtrap
SMTP_PASS=tu_contraseña_mailtrap
SMTP_FROM=noreply@agora.com

# URLs
FRONTEND_URL=http://localhost:5173

# Environment
NODE_ENV=development
